# LLM Provider: "azure" or "openai"
LLM_PROVIDER=azure

# Azure AI Foundry
AZURE_API_KEY=your-azure-api-key
AZURE_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview

# OpenAI direct (only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key

# Model overrides per job type (use Azure deployment names or OpenAI model IDs)
RELEVANCY_REVIEW_MODEL=gpt-5-nano
RELEVANCY_REVIEW_FALLBACK_MODEL=gpt-5-mini
RELEVANCY_REVIEW_CONFIDENCE_THRESHOLD=0.7


# MySQL
DATABASE_URL=mysql+pymysql://docreview:docreview@localhost:3306/docreview


# App
UPLOAD_DIR=./uploads
LOG_LEVEL=INFO
DEBUG=false
